{
  "name": "ai-webapp-starter-gcp",
  "private": true,
  "version": "0.1.0",
  "description": "AI 特化 Web サービス開発スターター (GCP)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,md}\"",
    "knip": "knip",
    "circular": "madge --circular --extensions ts,tsx apps/ packages/",
    "depcheck:api": "depcheck apps/api --ignores='@nestjs/schematics,source-map-support,reflect-metadata,ts-node,ts-node-dev,@typescript-eslint/*'",
    "depcheck:web": "depcheck apps/web --ignores='eslint-config-next'",
    "ncu": "ncu --deep",
    "sort-pkg": "sort-package-json package.json apps/*/package.json packages/*/package.json",
    "quality": "npm run format:check && npm run spell && npm run knip && npm run circular",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@playwright/test": "^1.48.0",
    "cspell": "^8.14.0",
    "depcheck": "^1.4.0",
    "husky": "^9.1.0",
    "knip": "^5.30.0",
    "lint-staged": "^15.2.0",
    "madge": "^8.0.0",
    "npm-check-updates": "^17.0.0",
    "prettier": "^3.3.0",
    "sort-package-json": "^2.10.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
