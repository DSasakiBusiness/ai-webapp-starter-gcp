# =============================================================================
# ai-webapp-starter-gcp 環境変数テンプレート
# このファイルを .env にコピーして、各値を設定してください
# cp .env.example .env
# =============================================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_webapp
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_webapp?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- API (NestJS) ---
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=your-jwt-secret-change-me
CORS_ORIGIN=http://localhost:3000

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-me

# --- LLM ---
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_AI_API_KEY=your-google-ai-api-key
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# --- RAG (optional) ---
# VECTOR_STORE_TYPE=pgvector
# EMBEDDING_MODEL=text-embedding-3-small

# --- GCP (production) ---
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=asia-northeast1
# GCS_BUCKET_NAME=your-bucket-name
# USE_GCS=false

# --- PentAGI (security testing only) ---
# PENTAGI_API_URL=http://localhost:8088
# PENTAGI_ENVIRONMENT=staging
